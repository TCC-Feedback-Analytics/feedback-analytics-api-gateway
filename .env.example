PORT=3000
NODE_ENV=development
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# URL publica do frontend (origem principal)
PUBLIC_SITE_URL=
# Lista de origens extras separadas por virgula
# Exemplo: https://feedback-analytics-web.vercel.app,https://app.suaempresa.com
CORS_ALLOWED_ORIGINS=
# Em preview da Vercel, habilita pareamento automatico entre web/api dos slugs configurados.
# Funciona mesmo quando os aliases de preview diferem entre projetos (ex.: -nando006 vs -git-homolog).
# Default efetivo: true em VERCEL_ENV=preview e false nos demais ambientes.
CORS_ALLOW_VERCEL_PROJECT_PAIR=
# Slugs de projeto usados no pareamento automatico de preview (web/api).
CORS_VERCEL_WEB_PROJECT_SLUG=feedback-analytics-web
CORS_VERCEL_API_PROJECT_SLUG=feedback-analytics-api
# true quando frontend e api estiverem em dominios diferentes
COOKIE_CROSS_SITE=false
IA_ANALYZE_EXECUTION_MODE=local
IA_ANALYZE_REMOTE_URL=
IA_ANALYZE_REMOTE_TOKEN=
IA_ANALYZE_REMOTE_FALLBACK_LOCAL=true
IA_ANALYZE_REMOTE_TIMEOUT_MS=10000
GEMINI_API_KEY=
