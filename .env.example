PORT=3000
NODE_ENV=development
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# URL publica do frontend (origem principal)
PUBLIC_SITE_URL=
# Lista de origens extras separadas por virgula
# Exemplo: https://feedback-analytics-web.vercel.app,https://app.suaempresa.com
CORS_ALLOWED_ORIGINS=
# true quando frontend e api estiverem em dominios diferentes
COOKIE_CROSS_SITE=false
IA_ANALYZE_EXECUTION_MODE=local
IA_ANALYZE_REMOTE_URL=
IA_ANALYZE_REMOTE_TOKEN=
IA_ANALYZE_REMOTE_FALLBACK_LOCAL=true
IA_ANALYZE_REMOTE_TIMEOUT_MS=10000
GEMINI_API_KEY=
