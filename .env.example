# Servidor HTTP do API Gateway.
PORT=3000 # Local
NODE_ENV=development # Local

# Origem principal do frontend e origens adicionais para CORS.
# Exemplo CORS_ALLOWED_ORIGINS: https://feedback-analytics-web.vercel.app,https://app.suaempresa.com
PUBLIC_SITE_URL= # Local/Preview/Produção
CORS_ALLOWED_ORIGINS= # Local/Preview/Produção

# Cookies em domínio cruzado (true quando web e api estão em domínios diferentes).
COOKIE_CROSS_SITE=false # Local/Preview/Produção

# Pareamento automático web/api em previews Vercel (aceita sufixos diferentes entre aliases).
CORS_ALLOW_VERCEL_PROJECT_PAIR= # Preview
CORS_VERCEL_WEB_PROJECT_SLUG=feedback-analytics-web # Preview
CORS_VERCEL_API_PROJECT_SLUG=feedback-analytics-api # Preview

# Integração com o serviço ia-analyze.
# local ou remote
IA_ANALYZE_EXECUTION_MODE=local # Local/Preview/Produção
IA_ANALYZE_REMOTE_URL= # Preview/Produção
IA_ANALYZE_REMOTE_PREVIEW_ALIAS_URL=https://feedback-analytics-ia-homolog.vercel.app # Preview (deve casar com o alias do deploy-ia-analyze.yml)
IA_ANALYZE_REMOTE_TOKEN= # Local/Preview/Produção
IA_ANALYZE_REMOTE_FALLBACK_LOCAL=true # Local/Preview/Produção
# Deve ficar com FOLGA abaixo do maxDuration do gateway no Vercel (300s), pois o
# gateway ainda faz consultas de banco antes/depois da IA. 280s garante que um
# timeout vire a mensagem clara "demorou demais" antes de o Vercel matar a função,
# e acomoda picos de latencia do Gemini. A analise real leva ~20-30s.
IA_ANALYZE_REMOTE_TIMEOUT_MS=280000 # Local/Preview/Produção

# Máx. de feedbacks por chamada ao Gemini. Lotes grandes geram um JSON de SAÍDA
# enorme que estoura o teto de tokens e trunca a resposta (→ erro). Default 20.
IA_MAX_FEEDBACKS_PER_BATCH=20 # Local/Preview/Produção


# Drizzle — conexão Postgres.
# Produção/homolog (Supabase, pooler): postgresql://postgres.<ref>:<senha>@<host>:5432/postgres
# Dev LOCAL (docker-compose, ver db/local/README.md) — porta 5433 no host:
#   DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/feedback
DATABASE_URL=postgresql://postgres.<ref>:<senha>@<host>:5432/postgres

# ─────────────────────────────────────────────────────────────────────────────
# Autenticação — Better Auth (único provedor do gateway).
# ─────────────────────────────────────────────────────────────────────────────
# Segredo do Better Auth (assina sessões). Gere: openssl rand -base64 32
# OBRIGATÓRIO: sem ele o getAuth() quebra no boot e o app não sobe. Trocá-lo
# invalida todas as sessões. Em prod, use o secret manager (nunca no repo).
BETTER_AUTH_SECRET= # Local/Preview/Produção (obrigatório)
# URL base da API (onde o handler /api/auth/* está montado).
BETTER_AUTH_URL=http://localhost:3000 # Local (em prod: URL pública da API)

# E-mail transacional (nodemailer via SMTP).
#  - Local: Mailpit (docker-compose) — captura sem enviar; UI em http://localhost:8025
#      SMTP_HOST=127.0.0.1  SMTP_PORT=1025  SMTP_SECURE=false  (sem user/pass)
#  - Prod: SendGrid SMTP — SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_SECURE=false
#      SMTP_USER=apikey  SMTP_PASS=<SENDGRID_API_KEY (SG.…)>
SMTP_HOST=127.0.0.1 # Local
SMTP_PORT=1025 # Local
SMTP_SECURE=false # Local
SMTP_USER= # Prod (SendGrid: "apikey")
SMTP_PASS= # Prod (SendGrid: sua API key SG.…)
MAIL_FROM=Feedback Analytics <no-reply@feedback.local> # Local/Preview/Produção

