# Servidor HTTP do API Gateway.
PORT=3000 # Local
NODE_ENV=development # Local

# Supabase usado pelo gateway para autenticação, sessão e dados.
VITE_SUPABASE_URL= # Local/Preview/Produção
VITE_SUPABASE_ANON_KEY= # Local/Preview/Produção

# Origem principal do frontend e origens adicionais para CORS.
# Exemplo CORS_ALLOWED_ORIGINS: https://feedback-analytics-web.vercel.app,https://app.suaempresa.com
PUBLIC_SITE_URL= # Local/Preview/Produção
CORS_ALLOWED_ORIGINS= # Local/Preview/Produção

# Cookies em domínio cruzado (true quando web e api estão em domínios diferentes).
COOKIE_CROSS_SITE=false # Local/Preview/Produção

# Pareamento automático web/api em previews Vercel (aceita sufixos diferentes entre aliases).
CORS_ALLOW_VERCEL_PROJECT_PAIR= # Preview
CORS_VERCEL_WEB_PROJECT_SLUG=feedback-analytics-web # Preview
CORS_VERCEL_API_PROJECT_SLUG=feedback-analytics-api # Preview

# Integração com o serviço ia-analyze.
IA_ANALYZE_EXECUTION_MODE=local # Local/Preview/Produção
IA_ANALYZE_REMOTE_URL= # Preview/Produção
IA_ANALYZE_REMOTE_PREVIEW_ALIAS_URL=https://feedback-analytics-service-ia-analysis-homolog.vercel.app # Preview
IA_ANALYZE_REMOTE_TOKEN= # Local/Preview/Produção
IA_ANALYZE_REMOTE_FALLBACK_LOCAL=true # Local/Preview/Produção
IA_ANALYZE_REMOTE_TIMEOUT_MS=10000 # Local/Preview/Produção




