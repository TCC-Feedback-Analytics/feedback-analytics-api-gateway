{
  "version": 2,
  "builds": [
    {
      "src": "_bundle.cjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 300
      }
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/_bundle.cjs"
    }
  ]
}
