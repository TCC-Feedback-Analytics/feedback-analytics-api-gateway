{
  "version": 2,
  "builds": [
    {
      "src": "backends/api-gateway/_bundle.cjs",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 120
      }
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backends/api-gateway/_bundle.cjs"
    }
  ]
}
