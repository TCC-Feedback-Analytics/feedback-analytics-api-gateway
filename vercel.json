{
  "version": 2,
  "installCommand": "npm ci --prefix shared && npm ci --prefix backends/api-gateway",
  "builds": [
    {
      "src": "backends/api-gateway/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "bundle": true
      }
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backends/api-gateway/index.ts"
    }
  ]
}