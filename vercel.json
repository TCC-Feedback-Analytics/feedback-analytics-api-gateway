{
  "version": 2,
  "builds": [
    {
      "src": "backends/api-gateway/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "/backends/api-gateway/index.ts"
    }
  ]
}